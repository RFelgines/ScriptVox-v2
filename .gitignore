# Python
__pycache__/
*.py[cod]
*.pyd
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment — never commit secrets
.env
*.env

# Databases
*.db
*.db-shm
*.db-wal

# Data directory — uploads and audio output (keep the placeholder)
# ⚠️ Never delete data/voice_uploads/ or data/voices/ during resets — they contain reference audio
data/*
!data/.gitkeep

# Isolated DATA_DIR for tests/check_phaseN.py (never the real data/ above)
data_test/

# Local test ebooks — copyrighted, never commit
Ebook/

# Reference audio for voice cloning spikes — user-provided, never commit
tests/refs/

# Piper local TTS — binary + voice models are large/GPL, downloaded per-machine
piper/
piper_*.zip
voices/*
!voices/.gitkeep

# Frontend — build artefacts and local env are machine-specific
frontend/node_modules/
frontend/.next/
frontend/.env.local

# Claude Code — local overrides are machine-specific, never commit (any nested dir too)
**/.claude/settings.local.json
**/.claude/launch.json

# Process artifacts — dev server pid files and redirected stdout/stderr logs
*.pid
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
