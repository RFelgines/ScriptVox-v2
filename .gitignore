# Python
__pycache__/
*.py[cod]
*.pyd
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment — never commit secrets
.env
*.env

# Databases
*.db
*.db-shm
*.db-wal

# Data directory — uploads and audio output (keep the placeholder)
data/*
!data/.gitkeep

# Piper local TTS — binary + voice models are large/GPL, downloaded per-machine
piper/
piper_*.zip
voices/*
!voices/.gitkeep

# Frontend — build artefacts and local env are machine-specific
frontend/node_modules/
frontend/.next/
frontend/.env.local

# Claude Code — local overrides are machine-specific, never commit
.claude/settings.local.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
