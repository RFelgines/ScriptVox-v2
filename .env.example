# ─── LLM Provider ────────────────────────────────────────────────────────────
# Which LLM backend to use: ollama (local) | gemini (cloud)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Fenêtre de contexte du modèle. 16384 tient 100% en VRAM sur une carte 10 Go avec
# qwen3:8b (pas de fallback CPU) ; combiné au découpage en chunks ci-dessous, c'est
# suffisant pour le prompt ET la sortie JSON (métadonnées only, label-based §2.7).
OLLAMA_CONTEXT_TOKENS=16384
# Budget de découpe d'un chapitre en chunks (tokens), découplé du contexte ci-dessus.
# Des chunks petits => sortie JSON courte par appel (pas de troncature de la liste
# d'attributions) + chaque appel rapide 100% GPU. ~4000 validé sur le pire chapitre HP.
OLLAMA_CHUNK_TOKENS=4000
OLLAMA_CONNECT_TIMEOUT=60
# Per-request read timeout = floor + (estimated prompt tokens / 1000) * per-1k-tokens.
# Floor covers small/medium chapters; the per-token term scales up for dense chapters
# and/or a slow/CPU-offloaded local model (see ARCHITECTURE.md §2.5).
OLLAMA_READ_TIMEOUT=600
OLLAMA_TIMEOUT_PER_1K_TOKENS=200

# Gemini settings (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── TTS Provider ────────────────────────────────────────────────────────────
# Which TTS backend to use: edgetts (default, free, no key) | piper (local, offline) |
# qwen (local, GPU, emotion per line — requires requirements-qwen.txt)
TTS_PROVIDER=edgetts

# EdgeTTS settings (used when TTS_PROVIDER=edgetts)
# BCP-47 locale — controls which neural voices are selected (en-US, fr-FR, de-DE, …)
EDGETTS_LOCALE=en-US

# Piper settings (used when TTS_PROVIDER=piper)
PIPER_VOICES_DIR=./voices
# Path to the piper executable (download from github.com/rhasspy/piper/releases)
PIPER_BINARY_PATH=./piper/piper.exe

# Qwen3-TTS settings (used when TTS_PROVIDER=qwen — requires `pip install -r requirements-qwen.txt`)
# Model variant: 1.7b (~4-6 GB VRAM, better quality) | 0.6b (smaller, faster)
QWEN_MODEL=1.7b
# Language passed to generate_custom_voice (e.g. French, English)
QWEN_LANGUAGE=French
# torch device string
QWEN_DEVICE=cuda:0
# Attention implementation: sdpa (no FlashAttention 2, recommended on Windows) | flash_attention_2
QWEN_ATTN=sdpa

# ─── Frontend / CORS ─────────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API (Next.js dev = http://localhost:3000)
FRONTEND_ORIGINS=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./scriptvox.db
HUEY_DB_PATH=./huey.db
