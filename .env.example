# ─── LLM Provider ────────────────────────────────────────────────────────────
# Quick start — pick ONE path:
#   • Fastest:    set LLM_PROVIDER=gemini and fill GEMINI_API_KEY below (just a key).
#   • Fully local: keep LLM_PROVIDER=ollama and install Ollama + pull the model
#                  (see README "Quick start"; `python scripts/doctor.py` tells you what's missing).
# Which LLM backend to use: ollama (local) | gemini (cloud)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
# qwen3:1.7b + think=False (natif, plus fiable que l'ancien suffixe /no_think) + les
# réparations d'attribution de _parse_llm_json battent qwen3:8b en vitesse ET en
# qualité sur un run HP complet mesuré (spike 2026-07-02) : 79% d'attribution en
# ~9 min contre 76% en ~24 min pour qwen3:8b. Voir ARCHITECTURE.md §2.7 / §2.5.
OLLAMA_MODEL=qwen3:1.7b
# 32768 tient 100% en VRAM avec qwen3:1.7b (poids ~1.4 Go) — contexte plein disponible,
# contrairement à qwen3:8b qui débordait sur le CPU à cette taille.
OLLAMA_CONTEXT_TOKENS=32768
# Budget de découpe d'un chapitre en chunks (tokens), découplé du contexte ci-dessus.
# Réglé pour qu'un chapitre HP tienne en un seul chunk (mesure validée) : découper
# inutilement fragmente la liste de personnages entre appels et peut dégrader
# l'attribution. Sur un modèle avec moins de marge VRAM, réduire au besoin.
OLLAMA_CHUNK_TOKENS=26000
OLLAMA_CONNECT_TIMEOUT=60
# Per-request read timeout = floor + (estimated prompt tokens / 1000) * per-1k-tokens.
# Floor covers small/medium chapters; the per-token term scales up for dense chapters
# and/or a slow/CPU-offloaded local model (see ARCHITECTURE.md §2.5).
OLLAMA_READ_TIMEOUT=600
OLLAMA_TIMEOUT_PER_1K_TOKENS=200

# Gemini settings (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── TTS Provider ────────────────────────────────────────────────────────────
# Which TTS backend to use: edgetts (default, free, no key) | piper (local, offline) |
# qwen (local, GPU, emotion per line — requires requirements-qwen.txt)
TTS_PROVIDER=edgetts

# EdgeTTS settings (used when TTS_PROVIDER=edgetts)
# BCP-47 locale — controls which neural voices are selected (en-US, fr-FR, de-DE, …)
EDGETTS_LOCALE=en-US

# Piper settings (used when TTS_PROVIDER=piper)
PIPER_VOICES_DIR=./voices
# Path to the piper executable (download from github.com/rhasspy/piper/releases)
PIPER_BINARY_PATH=./piper/piper.exe

# Qwen3-TTS settings (used when TTS_PROVIDER=qwen — requires `pip install -r requirements-qwen.txt`)
# Model variant: 1.7b (~4-6 GB VRAM, better quality) | 0.6b (smaller, faster)
QWEN_MODEL=1.7b
# Language passed to generate_custom_voice (e.g. French, English)
QWEN_LANGUAGE=French
# torch device string
QWEN_DEVICE=cuda:0
# Attention implementation: sdpa (no FlashAttention 2, recommended on Windows) | flash_attention_2
QWEN_ATTN=sdpa

# ─── Frontend / CORS ─────────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API (Next.js dev = http://localhost:3000)
FRONTEND_ORIGINS=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./scriptvox.db
HUEY_DB_PATH=./huey.db
# Dossier de stockage des fichiers (couvertures, audio, voix clonées). Obligatoire
# (pas de défaut silencieux) : chaque tests/check_phaseN.py DOIT pointer vers un
# dossier isolé (ex. ./data_test), jamais ce chemin réel — incident 2026-07-02 où
# des tests ont écrasé de vraies couvertures/audio via un chemin codé en dur.
DATA_DIR=data
